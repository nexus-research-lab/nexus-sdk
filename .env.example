# Copy this file to `.env` and fill only the providers / backends you need.
#
# Usage:
#   cp .env.example .env
#   PYTHONPATH=. python3 examples/provider_smoke.py --provider openai --model gpt-4.1

# ------------------------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# ------------------------------------------------------------------------------
# Anthropic
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_API_VERSION=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_REASONING_MODEL=

# ------------------------------------------------------------------------------
# Azure OpenAI
# ------------------------------------------------------------------------------
# Example endpoint:
#   https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OPENAI_API_VERSION=

# Optional: use Microsoft Entra ID instead of API key.
# Set to true/1/yes/on to enable token-provider mode.
AZURE_OPENAI_USE_ENTRA_ID=false
AZURE_OPENAI_AD_TOKEN=

# ------------------------------------------------------------------------------
# Session backends
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://user:password@localhost:5432/nexus_sdk
SESSION_ID=demo-session
SESSION_TTL_SECONDS=

# ------------------------------------------------------------------------------
# Optional encryption wrapper
# ------------------------------------------------------------------------------
# Generate with:
#   python3 -c "from rich_agent.sessions import EncryptedSession; print(EncryptedSession.generate_key())"
ENCRYPTED_SESSION_KEY=

# ------------------------------------------------------------------------------
# Smoke test defaults
# ------------------------------------------------------------------------------
OPENAI_MODEL=gpt-4.1
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AZURE_OPENAI_MODEL=your-deployment-name
SMOKE_PROMPT=Reply with the word READY.
